# RDBMS Response File – RAC
# Gerenciado pelo Ansible – oradb_install
# Gerado em: {{ ansible_date_time.iso8601 }}
# Oracle Version: {{ oracle_version }}

oracle.install.responseFileVersion=/oracle/install/rspfmt_dbinstall_response_schema_v19.0.0

# ── Opção de instalação ───────────────────────────────────────────────────────
oracle.install.option=INSTALL_DB_SWONLY

# ── Hostname ──────────────────────────────────────────────────────────────────
ORACLE_HOSTNAME={{ ansible_fqdn }}

# ── Diretórios ────────────────────────────────────────────────────────────────
UNIX_GROUP_NAME={{ oracle_group }}
INVENTORY_LOCATION={{ oracle_inventory_location }}
ORACLE_HOME={{ oracle_home }}
ORACLE_BASE={{ oracle_base }}

# ── Edição ────────────────────────────────────────────────────────────────────
oracle.install.db.InstallEdition={{ oracle_edition }}

# ── Grupos DBA ────────────────────────────────────────────────────────────────
oracle.install.db.OSDBA_GROUP={{ oracle_dba_group }}
oracle.install.db.OSOPER_GROUP={{ oracle_oper_group }}
oracle.install.db.OSBACKUPDBA_GROUP={{ oracle_backupdba_group }}
oracle.install.db.OSDGDBA_GROUP={{ oracle_dgdba_group }}
oracle.install.db.OSKMDBA_GROUP={{ oracle_kmdba_group }}
oracle.install.db.OSRACDBA_GROUP={{ oracle_racdba_group }}

# ── RAC ───────────────────────────────────────────────────────────────────────
oracle.install.db.rootconfig.executeRootScript=false
oracle.install.db.rootconfig.configMethod=ROOT
oracle.install.db.isRACOneInstall=false
oracle.install.db.rac.serverpoolCardinality=0

# ── Nós do cluster ────────────────────────────────────────────────────────────
oracle.install.db.CLUSTER_NODES={% for node in oracle_cluster_nodes %}{{ node.hostname }}{% if not loop.last %},{% endif %}{% endfor %}


# ── Atualizações automáticas ──────────────────────────────────────────────────
oracle.installer.autoupdates.option=SKIP_UPDATES

# ── Configurações de segurança ────────────────────────────────────────────────
DECLINE_SECURITY_UPDATES=true