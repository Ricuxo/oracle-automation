# ~/.bash_aliases
# Gerenciado pelo Ansible – orahost_directories
# Alterações manuais serão sobrescritas

# ── Navegação ─────────────────────────────────────────────────────────────────
alias dba='cd $SQLPATH'
alias sqlnet='cd $ORACLE_HOME/network/admin ; ls -ltr'

# ── SQLPlus / ASM ─────────────────────────────────────────────────────────────
alias sql='rlwrap sqlplus / as sysasm'
alias asmcmd='rlwrap asmcmd -p'
alias adrci='rlwrap adrci'

# ── Alert log ─────────────────────────────────────────────────────────────────
alias alert="tail -100f $ORACLE_BASE/diag/asm/\`echo \$ORACLE_SID | sed 's/.\{0\}$//' | tr [:upper:] [:lower:]\`/\$ORACLE_SID/trace/alert_\$ORACLE_SID.log"
alias goalert="cd $ORACLE_BASE/diag/asm/\`echo \$ORACLE_SID | sed 's/.\{0\}$//' | tr [:upper:] [:lower:]\`/\$ORACLE_SID/trace ; ls -ltr"

# ── CRS ───────────────────────────────────────────────────────────────────────
alias crs_status="\`ps -ef | grep ocssd.bin | sed 's/.\{15\}$//' | awk {'print \$8'}\`/bin/crsctl stat res -t"
alias crslog="cd \`ps -ef | grep ocssd.bin | sed 's/.\{15\}$//' | awk {'print \$8'}\`/log/\`hostname -s\` ; ls -ltr"

# ── ASM ───────────────────────────────────────────────────────────────────────
alias free_asm="rlwrap sqlplus / as sysasm @\$SQLPATH/free_asm.sql"
alias asm_disks="rlwrap sqlplus / as sysasm @\$SQLPATH/asm_disks.sql"

# ── RAC ───────────────────────────────────────────────────────────────────────
alias dfu='for i in `$ORACLE_HOME/bin/olsnodes`; do ssh $i "( hostname; df -h)"; done'
alias big_files='sh $SQLPATH/find.sh'

# ── Backup ────────────────────────────────────────────────────────────────────
alias bkp='cd /var/opt/omni/tmp ; ls -l'